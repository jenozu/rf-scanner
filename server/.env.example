# Backend environment variables (copy to server/.env for local dev)

NODE_ENV=development
PORT=3001

# Where JSON data files are stored. Defaults to ./data (relative to server/) if not set.
DATA_DIR=

# Change this to a long random string in any shared/production environment
JWT_SECRET=rf-scanner-secret-key-change-in-production

# SAP SQL Server connection (only needed for inventory/PO export scripts)
SQL_SERVER=
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
DB_DRIVER={ODBC Driver 17 for SQL Server}

# Purolator shipping API (only needed for shipping features)
PUROLATOR_API_USERNAME=
PUROLATOR_API_PASSWORD=
PUROLATOR_API_ACCOUNT=

# Email for shipping labels (optional)
EMAIL_FROM=
EMAIL_PASSWORD=
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
